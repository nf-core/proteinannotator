/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
*/

// TODO nf-core: Specify any additional parameters here
// Or any resources requirements
params.modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
params.pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/proteinannotator'

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners
params.outdir = './results'

process {
    withName: NCBIREFSEQDOWNLOAD {
        cpus= 1
        memory= 4.GB
    }
}

process {
    withName: DIAMONDPREPARETAXA {
        cpus= 1
        memory= 4.GB
    }
}

process {
    withName: DIAMOND_MAKEDB {
        cpus= 1
        memory= 4.GB
    }
}

process {
    withName: DIAMOND_BLASTP {
        cpus= 1
        memory= 4.GB
    }
}
// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core modules test interproscan/setup
nextflow_process {

    name "Test Process INTERPROSCAN_SETUP"
    script "../main.nf"
    process "INTERPROSCAN_SETUP"

    tag "modules"
    tag "modules_"
    tag "interproscan"
    tag "interproscan/setup"
    tag "untar"

    test("interproscan - setup") {

        setup {
            // Untar the tar.gz interproscan file, because this is how it will be presented to the pipeline
            run("UNTAR") {
                script "modules/nf-core/untar/main.nf"
                process {
                    """
                    input[0] = [
                        [ id: 'interproscan-5.73-104.0' ], // meta map
                        file("${moduleDir}/tests/fixtures/interproscan-5.73-104.0.tar.gz", checkIfExists: true)
                    ]
                    """
                }
            }
        }

        when {
            process {
                """
                interproscan_db_unzipped = UNTAR.out.untar.map{ meta, folder -> folder }
                interproscan_db_unzipped.view()
                interproscan_db_unzipped_data = interproscan_db_unzipped.resolve('data')
                interproscan_db_unzipped_data.view()
                input[0] = [ interproscan_db_unzipped_data,  "5.73-104.0" ]
                """

            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}

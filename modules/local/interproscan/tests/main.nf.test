nextflow_process {

    name "Test Process INTERPROSCAN"
    script "../main.nf"
    process "INTERPROSCAN"
    config "./nextflow.config"
    tag "modules"
    tag "modules_nfcore"
    tag "interproscan"

    // Note: Regular tests have been commented out because Interproscan has a harded coded a requirement of 10G memory,
    // and so will therefore not run on the nf-core test runners without being killed.

    test("test_interproscan") {

        tag "full"

        when {

            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file("${moduleDir}/tests/fixtures/test.fasta", checkIfExists: true)
                ]
                input[1] = [
                    file("${moduleDir}/tests/fixtures/interproscan_db/data", type: "dir", checkIfExists: true),
                    "5.73-104.0"
                ]
                """
            }
        }

        then {
            // Helper to write gzipped content
            def writeGzip = { file, content ->
                def fos = new FileOutputStream(file)
                def gos = new java.util.zip.GZIPOutputStream(fos)
                gos.write(content.getBytes('UTF-8'))
                gos.close()
                fos.close()
            }

            // Replace date strings in gzipped tsv and gff3 files
            def tsv_path = process.out.tsv.get(0).get(1)
            def gff3_path = process.out.gff3.get(0).get(1)
            def tsv_content = path(tsv_path).getTextGzip().replaceAll(/\d{2}-\d{2}-\d{4}/, "dd-mm-yyyy")
            def gff3_content = path(gff3_path).getTextGzip().replaceAll(/\d{2}-\d{2}-\d{4}/, "dd-mm-yyyy")

            println tsv_content
            println gff3_content

            // Write back modified content as gzipped
            writeGzip(tsv_path, tsv_content)
            writeGzip(gff3_path, gff3_content)

            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
            )
        }
    }

    test("stub") {
        tag "stub"
        tag "CI"
        options "-stub"

        when {

            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file("${moduleDir}/tests/fixtures/test.fasta", checkIfExists: true)
                ]
                input[1] = [
                    file("${moduleDir}/tests/fixtures/interproscan_db/data", type: "dir", checkIfExists: true),
                    "5.73-104.0"
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}

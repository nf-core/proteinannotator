
nextflow_process {

    name "Test Process INTERPROSCAN_RUN"
    script "../main.nf"
    process "INTERPROSCAN_RUN"

    tag "modules"
    tag "modules_"
    tag "interproscan"
    tag "interproscan/run"

    test("interproscan - run") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file("${moduleDir}/tests/fixtures/test.fasta", checkIfExists: true)
                ]
                input[1] = [
                    file("${moduleDir}/tests/fixtures/interproscan_db/data", type: 'dir', checkIfExists: true),
                    "5.73-104.0"
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}

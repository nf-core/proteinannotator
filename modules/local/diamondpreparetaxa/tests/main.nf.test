nextflow_process {

    name "Test Process DIAMONDPREPARETAXA"
    script "../main.nf"
    process "DIAMONDPREPARETAXA"

    tag "modules"
    tag "modules_"
    tag "diamondpreparetaxa"

    test("Test DIAMONDPREPARETAXA creates taxon nodes and names dmp files") {

        when {
            process {
                """
                input[0] = 'ftp://ftp.ncbi.nih.gov/pub/taxonomy/taxdump.tar.gz'
                
                // input[0] = [
                //     [ id:'test', single_end:false ], // meta map
                //     file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                // ]
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
            // assert process.out.taxonnodes.exists()
            // { assert process.out.get(0).exists() }
            assert snapshot(process.out.versions).match("versions")
            //TODO nf-core: Add all required assertions to verify the test output.
            // See https://nf-co.re/docs/contributing/tutorials/nf-test_assertions for more information and examples.
            }

    }

